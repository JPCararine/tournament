# Copie este arquivo para .env e preencha os valores reais.
# O .env NAO e versionado (esta no .gitignore).

# ---------------------------------------------------------------------------
# Banco de dados
# Em deploy via docker compose, o DATABASE_URL e sobrescrito automaticamente
# para apontar ao servico "db". Os valores abaixo alimentam o container MySQL.
# ---------------------------------------------------------------------------
DATABASE_NAME=tournament
DATABASE_USERNAME=sgtourcs2
DATABASE_PASSWORD=troque-esta-senha
DATABASE_ROOT_PASSWORD=troque-a-senha-root
# Usado apenas ao rodar fora do Docker (ex.: mvnw local):
DATABASE_URL=jdbc:mysql://localhost:3306/tournament

# ---------------------------------------------------------------------------
# Asaas (gateway Pix)
# ---------------------------------------------------------------------------
# Use https://api.asaas.com em producao e https://api-sandbox.asaas.com em sandbox.
ASAAS_API_URL=https://api.asaas.com
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_PIX_KEY=
ASAAS_AMOUNT_CENTS=5000
# Prazo de expiracao do Pix em segundos (3600 = 1h). Tambem define em quanto
# tempo uma equipe PENDENTE nao paga e removida automaticamente.
ASAAS_PIX_EXPIRES_SECONDS=3600

# ---------------------------------------------------------------------------
# SendGrid (e-mail transacional via SMTP relay)
# ---------------------------------------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ---------------------------------------------------------------------------
# Aplicacao
# ---------------------------------------------------------------------------
DISCORD_INVITE_URL=
CORS_ALLOWED_ORIGINS=http://localhost:5173
# URL publica do backend (para o QR Code nos e-mails e para o webhook):
APP_PUBLIC_BASE_URL=http://localhost:8080

# Copie este arquivo para .env e preencha os valores reais.
# O .env NÃO é versionado (está no .gitignore).

# ---------------------------------------------------------------------------
# Banco de dados
# Em deploy via docker compose, o DATABASE_URL é sobrescrito automaticamente
# para apontar ao serviço "db". Os valores abaixo alimentam o container MySQL.
# ---------------------------------------------------------------------------
DATABASE_NAME=tournament
DATABASE_USERNAME=sgtourcs2
DATABASE_PASSWORD=troque-esta-senha
DATABASE_ROOT_PASSWORD=troque-a-senha-root
# Usado apenas ao rodar fora do Docker (ex.: mvnw local):
DATABASE_URL=jdbc:mysql://localhost:3306/tournament

# ---------------------------------------------------------------------------
# AbacatePay (gateway Pix)
# ---------------------------------------------------------------------------
ABACATEPAY_API_URL=https://api.abacatepay.com
ABACATEPAY_TOKEN=
ABACATEPAY_WEBHOOK_SECRET=
ABACATEPAY_AMOUNT_CENTS=5000

# ---------------------------------------------------------------------------
# SendGrid (e-mail transacional via SMTP relay)
# ---------------------------------------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ---------------------------------------------------------------------------
# Aplicação
# ---------------------------------------------------------------------------
DISCORD_INVITE_URL=
CORS_ALLOWED_ORIGINS=http://localhost:5173
# URL pública do backend (para o QR Code nos e-mails e para o webhook):
APP_PUBLIC_BASE_URL=http://localhost:8080
